<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BeatDrop" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!--
          Splash colour matches the MIDDLE of the in-app Laisacorp splash
          gradient (#1A1020 → #151025 → #12121A) so the handover from
          system splash → SplashScreen.kt is visually seamless: same logo,
          same colour family, no jarring background swap. On Android 12+
          the system splash is unavoidable, so the next best thing is to
          make it indistinguishable from the branded splash that follows.
        -->
        <item name="android:windowBackground">#151025</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">#151025</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/beatdrop_logo</item>
        <!--
          Suppress the icon-background ring on Android 12L+ so the logo
          appears flat against the splash background, exactly like it
          does in SplashScreen.kt. Without this the system would draw a
          subtle white circle behind the logo on some OEMs.
        -->
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="v">#151025</item>
    </style>
</resources>
